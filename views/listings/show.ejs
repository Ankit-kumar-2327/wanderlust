
<%- layout("/layouts/boilerplate") %>
<script>
    let mapToken = "<%= process.env.MAP_TOKEN %>";
    let listing = <%- JSON.stringify(listing) %>;
</script>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3><%= listing.title %></h3>
        </div>
        <div class="col col-6 offset-md-2">
            <div class="card listing-card" style="width: 18rem;">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image">
                <div class="card-body">
                    <p class="card-text">Owned by:<i><%= listing.owner.username %></i></p>
                    <p class="card-text"><%= listing.description %></p>
                    <p class="card-text"><b>Price: </b>&#8377;<%= listing.price.toLocaleString("en-IN") %></p>
                    <p class="card-text"><b>Location: </b><%= listing.location %></p>
                    <p class="card-text"><b>Country: </b><%= listing.country %></p>
                </div>
            </div>
        </div>

        <div class="btns">
            <a href="/listings/<%= listing._id %>/edit"
                class="btn btn-dark col-1 offset-2 edit-btn">edit
            </a>
            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                <button type="submit" class="btn btn-danger offset-4">delete</button>
            </form>
        </div>

            <hr>
            <div class="row col-8 offset-2">
                <h4>Leave a Review</h4>
                <form method="POST" action="/listings/<%= listing.id %>/reviews" class="needs-validation" novalidate>
                    <div class="col mb-3 mt-3">
                        <label  for="rating" class="form-label">Rating</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <div class=" col mb-3 mt-3">
                        <label for="comment" class="form-label">Comments</label>
                        <textarea rows="5" cols="10" name="review[comment]" class ="form-control" required></textarea>
                        <div class="invalid-feedback">Please add some comments for review</div>
                    </div>
                    <button class="btn btn-outline-primary mb-2">submit</button>
                </form>
            </div>
            <hr>
            <% if (listing.reviews.length > 0) { %>
                <div class="row col-10 offset-2">
                    <p><b>All Reviews</b></p>
                    <% for(review of listing.reviews) { %>
                        <div class="card col-5 mb-3 ms-3">
                            <div class="card-body mt-1 ms-2">
                                <h5 class="card-title">@<%= review.createdBy.username %></h5>
                                <p class=" card-text starability-result" data-rating= "<%= review.rating %>"></p>
                                <p class="card-text"><%= review.comment %></p>
                            </div>
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-1">
                                <button class="btn btn-dark">delete review</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
    <div class=" col mb-3 mt-3 offset-1">
        <h4>Where you’ll be</h4> <br>
        <h5><%= listing.location %></h5>
        <div id="map"></div>
    </div>
    <script src="/js/map.js"></script>
</body>